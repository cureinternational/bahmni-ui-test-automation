# Environment Configuration Template
# Copy this file to .env.et, .env.niger, or .env.local and update with your values
# IMPORTANT: Never commit actual .env.* files with real credentials to git!

# =============================================================================
# REQUIRED: Base URL (all other URLs will be derived from this if not specified)
# =============================================================================
BASE_URL=

# =============================================================================
# OPTIONAL: Application URLs (if not set, will be constructed from BASE_URL)
# =============================================================================
# Only set these if your Bahmni instance has custom URL patterns
# LOGIN_URL=https://your-bahmni-instance.com/bahmni/home/index.html#/login
# LOCATION_URL=https://your-bahmni-instance.com/bahmni/home/index.html#/loginLocation
# DASHBOARD_URL=https://your-bahmni-instance.com/bahmni/home/index.html#/dashboard
# REGISTRATION_SEARCH_URL=https://your-bahmni-instance.com/bahmni-new/registration/search
# REGISTRATION_NEW_PATIENT_URL=https://your-bahmni-instance.com/bahmni-new/registration/patient/new
# CLINICAL_SEARCH_URL=https://your-bahmni-instance.com/bahmni/clinical/index.html#/default/patient/search

# =============================================================================
# REQUIRED: User Credentials (base64 encoded)
# =============================================================================
# Note: Encode your credentials using: echo -n 'your-username' | base64
# Admin User (for setup, API calls, and admin operations)
USER_ADMIN_USERNAME=b3RoZXIuZG9jdG9y
USER_ADMIN_PASSWORD=U2VjcmV0MDA3

# Doctor User (for clinical tests)
USER_DOCTOR_USERNAME=eW91ci1kb2N0b3ItdXNlcm5hbWU=
USER_DOCTOR_PASSWORD=eW91ci1kb2N0b3ItcGFzc3dvcmQ=

# Nurse User (for nursing tests)
USER_NURSE_USERNAME=eW91ci1udXJzZS11c2VybmFtZQ==
USER_NURSE_PASSWORD=eW91ci1udXJzZS1wYXNzd29yZA==

# Receptionist User (for registration tests)
USER_RECEPTIONIST_USERNAME=eW91ci1yZWNlcHRpb25pc3QtdXNlcm5hbWU=
USER_RECEPTIONIST_PASSWORD=eW91ci1yZWNlcHRpb25pc3QtcGFzc3dvcmQ=

# =============================================================================
# OPTIONAL: Default Settings
# =============================================================================
# Default user role for tests (admin, doctor, nurse, or receptionist)
DEFAULT_USER=admin

# Default locale (string:en, string:es, string:fr, etc.)
DEFAULT_LOCALE=string:en

# Default location for login
DEFAULT_LOCATION=OPD-1

# =============================================================================
# OPTIONAL: Playwright Configuration
# =============================================================================
# Run tests in headless mode (true/false)
HEADLESS=false

# Default timeout for actions (in milliseconds)
TIMEOUT=30000

# Slow down actions by specified milliseconds (useful for debugging)
SLOW_MO=100

# Browser viewport dimensions
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# =============================================================================
# OPTIONAL: Test Data Defaults
# =============================================================================
DEFAULT_PATIENT_PHONE=9876543210
DEFAULT_PATIENT_EMAIL=test@example.com

{
  "name": "bahmni-ui-automation",
  "version": "1.0.0",
  "description": "Automated test suite for Bahmni 3.0 UI - functional, E2E, and visual regression testing using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=et npx playwright test",
    "test:et": "NODE_ENV=et npx playwright test",
    "test:niger": "NODE_ENV=niger npx playwright test",
    "test:local": "NODE_EXTRA_CA_CERTS=/tmp/bahmni-cert.pem NODE_ENV=local npx playwright test",
    "test:headed": "NODE_ENV=et npx playwright test --headed",
    "test:headed:local": "NODE_EXTRA_CA_CERTS=/tmp/bahmni-cert.pem NODE_ENV=local npx playwright test --headed",
    "test:ui": "NODE_ENV=et npx playwright test --ui",
    "test:debug": "NODE_ENV=et npx playwright test --debug",
    "test:chromium": "NODE_ENV=et npx playwright test --project=chromium",
    "test:firefox": "NODE_ENV=et npx playwright test --project=firefox",
    "report": "npx playwright show-report reports/html-report",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results",
    "allure:clean": "rm -rf reports/allure-results reports/allure-report",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@percy/cli": "^1.31.8",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
